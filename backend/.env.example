# Environment variables example
# Copy this file to .env and fill in real values there. Never commit .env.

# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# --- Database (Supabase Postgres) ---
DATABASE_URL=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- JWT ---
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Redis (Upstash) ---
REDIS_URL=

# --- Judge0 ---
JUDGE0_BASE_URL=
JUDGE0_API_KEY=
